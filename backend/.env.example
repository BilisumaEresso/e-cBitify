PORT=8000
CONNECTION_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
JWT_KEY=your_jwt_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenAI (for AI search/recommendations)
OPENAI_API_KEY=your_openai_key
 
# CORS — set to your frontend URL
# Development:  http://localhost:5173
# Production:   https://your-deployed-frontend.com
FRONTEND_URL=http://localhost:5173

# Set to "development" to see stack traces in error responses
NODE_ENV=development
